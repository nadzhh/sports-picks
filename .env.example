# .env.example - template pour le dev local
# Copie ce fichier en .env (qui sera gitignore) et remplis avec tes vraies cles.
# Sur GitHub Actions, les valeurs sont fournies par Settings -> Secrets and variables.

# api-football (api-sports.io)
API_KEY=

# The Odds API (the-odds-api.com)
ODDS_API_KEY=

# Telegram bot (token recupere via @BotFather)
TELEGRAM_BOT_TOKEN=

# Telegram chat_id (recupere via : python notify.py setup)
TELEGRAM_CHAT_ID=
